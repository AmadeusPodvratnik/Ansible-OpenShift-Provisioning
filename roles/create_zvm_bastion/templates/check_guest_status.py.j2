#!/usr/bin/env python3
"""
Check z/VM guest status using tessia-baselib
"""

import sys
from tessia.baselib.hypervisors.zvm.zvm import HypervisorZvm

def check_guest_status():
    """
    Check if z/VM guest exists and its status
    
    Returns:
        0 on success, 1 on failure
    """
    # z/VM connection parameters
    zvm_name = "{{ inventory_hostname }}"
    zvm_host = "{{ zvm_host }}"
    zvm_user = "{{ zvm_user }}"
    zvm_pass = "{{ zvm_pass }}"
    guest_name = "{{ zvm_guest }}"
    
    try:
        print(f"Checking status of guest: {guest_name}")
        
        # Connection parameters
        parameters = {
            'transfer-buffer-size': 8000
        }
        
        # Create HypervisorZvm instance
        zvm = HypervisorZvm(zvm_name, zvm_host, zvm_user, zvm_pass, parameters)
        
        # Login to z/VM
        zvm.login()
        
        # Query guest status
        try:
            status = zvm.query_guest(guest_name)
            print(f"✓ Guest {guest_name} exists")
            print(f"Status: {status}")
        except Exception as e:
            print(f"⚠ Could not query guest status: {str(e)}")
            print(f"Guest {guest_name} may not be fully configured yet")
        
        # Logoff
        zvm.logoff()
        
        return 0
        
    except Exception as e:
        print(f"✗ Failed to check guest status: {str(e)}", file=sys.stderr)
        return 1

if __name__ == "__main__":
    sys.exit(check_guest_status())