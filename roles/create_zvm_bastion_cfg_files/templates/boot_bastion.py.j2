#!/usr/bin/env python3
"""
Boot zVM guest for bastion installation using Tessia base lib
Generated by Ansible create_bastion_zvm_tessia role
"""
from tessia.baselib.hypervisors.zvm.zvm import HypervisorZvm
import argparse
import sys

def main():
    parser = argparse.ArgumentParser(description="Boot zVM guest for bastion")
    parser.add_argument("--zvmname", type=str, required=True, help="zVM guest name")
    parser.add_argument("--zvmhost", type=str, required=True, help="zVM hostname/IP")
    parser.add_argument("--zvmuser", type=str, required=True, help="zVM admin user")
    parser.add_argument("--zvmpass", type=str, required=True, help="zVM password")
    parser.add_argument("--cpu", type=int, required=True, help="Number of CPUs")
    parser.add_argument("--memory", type=int, required=True, help="Memory in MB")
    parser.add_argument("--kernel", type=str, required=True, help="Kernel URI")
    parser.add_argument("--initrd", type=str, required=True, help="Initrd URI")
    parser.add_argument("--cmdline", type=str, required=True, help="Kernel cmdline")
    parser.add_argument("--network", type=str, required=True, help="Network mode")
    parser.add_argument("--disk_type", type=str, required=True, help="Disk device type [ECKD, FCP]")
    parser.add_argument("--disk_dev", type=str, action="append", help="Disk device to attach")
    parser.add_argument("--fcp_rport", type=str, action="append", help="FCP Remote Port WWPN")
    parser.add_argument("--fcp_lun", type=str, action="append", help="FCP LUN")

    args = parser.parse_args()

    # Tessia parameters
    parameters = {
        'transfer-buffer-size': {{ tessia_transfer_buffer_size }}
    }

    # Network interface configuration
    interfaces = []
{% if zrd_network_mode | lower == 'osa' or zrd_network_mode | lower == 'vswitch' %}
    # OSA or vSwitch configuration
    interfaces = [{
        "type": "osa",
        "id": "{{ zrd_znet[0].split(',') | reject('match', '^(qeth|layer2=.*)$') | map('regex_replace', '^0\\.0\\.', '') | join(',') }}"
    }]
{% elif zrd_network_mode | lower == 'roce' %}
    # RoCE configuration
    interfaces = [{
        "type": "pci",
        "id": "{{ network[0].device }}"
    }]
{% elif 'hipersockets' in zrd_network_mode | lower %}
    # Hipersockets configuration
    interfaces = [{
        "type": "osa",
        "id": "{{ zrd_znet[0].split(',') | reject('match', '^(qeth|layer2=.*)$') | map('regex_replace', '^0\\.0\\.', '') | join(',') }}"
    }]
{% endif %}

    # Disk configuration
    disks = []
    if args.disk_type.upper() in ['ECKD', 'EDEV']:
        # DASD/ECKD disk configuration
        if args.disk_dev:
            for disk_dev in args.disk_dev:
                disks.append({
                    "type": "dasd",
                    "devno": disk_dev
                })
    elif args.disk_type.upper() == 'FCP':
        # FCP disk configuration
        if args.disk_dev and args.fcp_rport and args.fcp_lun:
            # Clean WWPNs - remove 0x prefix and ensure 16 hex chars
            wwpns_clean = []
            for wwpn in args.fcp_rport:
                wwpn_clean = wwpn.replace('0x', '').replace('0X', '')
                if wwpn_clean not in wwpns_clean:  # Avoid duplicates
                    wwpns_clean.append(wwpn_clean)
            
            # Build adapters list - each adapter has devno and array of wwpns
            adapters = []
            for disk_dev in args.disk_dev:
                adapters.append({
                    "devno": disk_dev,
                    "wwpns": wwpns_clean
                })
            
            # Build LUN configuration - one disk per unique LUN
            seen_luns = set()
            for lun in args.fcp_lun:
                # Remove 0x prefix if present and ensure 16 hex chars
                lun_clean = lun.replace('0x', '').replace('0X', '')
                if lun_clean not in seen_luns:
                    seen_luns.add(lun_clean)
                    disks.append({
                        "type": "fcp",
                        "adapters": adapters,
                        "lun": lun_clean
                    })

    # Guest boot parameters
    guest_parameters = {
        "boot_method": "network",
        "storage_volumes": disks,
        "ifaces": interfaces,
        "netboot": {
            "cmdline": args.cmdline,
            "kernel_uri": args.kernel,
            "initrd_uri": args.initrd,
        }
    }

    try:
        # Connect to z/VM
        print(f"Connecting to z/VM: {args.zvmhost}")
        zvm = HypervisorZvm(args.zvmname, args.zvmhost, args.zvmuser, args.zvmpass, parameters)
        zvm.login()
        print("✓ Logged in to z/VM")
        
        # Start guest
        print(f"Starting guest: {args.zvmname}")
        print(f"  CPU: {args.cpu}")
        print(f"  Memory: {args.memory}MB")
        print(f"  Network mode: {args.network}")
        print(f"  Disk type: {args.disk_type}")
        if disks:
            print(f"  Storage volumes: {len(disks)} disk(s) configured")
        zvm.start(args.zvmuser, args.cpu, args.memory, guest_parameters)
        print("✓ Guest started successfully")
        print("✓ OS installation initiated")
        
        # Logoff
        zvm.logoff()
        print("✓ Logged out from z/VM")
        
        print("\nGuest is now booting and installing OS...")
        print("This process will take approximately 15-25 minutes.")
        
    except Exception as e:
        print(f"✗ Error: {str(e)}", file=sys.stderr)
        import traceback
        traceback.print_exc()
        sys.exit(1)

if __name__ == "__main__":
    main()