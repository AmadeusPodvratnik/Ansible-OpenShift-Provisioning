#!/usr/bin/env python3
"""
Test z/VM hypervisor connectivity using tessia-baselib
"""
from tessia.baselib.hypervisors.zvm.zvm import HypervisorZvm
import sys

def test_zvm_connection(zvm_name, zvm_host, zvm_user, zvm_pass):
    """
    Test connection to z/VM hypervisor
    
    Args:
        zvm_name: z/VM hypervisor name
        zvm_host: z/VM hostname or IP
        zvm_user: z/VM admin user
        zvm_pass: z/VM admin password
    
    Returns:
        0 on success, 1 on failure
    """
    try:
        # Connection parameters
        parameters = {
            'transfer-buffer-size': 8000
        }
        
        # Create HypervisorZvm instance
        print(f"Connecting to z/VM hypervisor: {zvm_host}")
        zvm = HypervisorZvm(zvm_name, zvm_host, zvm_user, zvm_pass, parameters)
        
        # Attempt login
        print("Attempting login...")
        zvm.login()
        print("✓ Successfully logged in to z/VM hypervisor")
        
        # Logoff
        zvm.logoff()
        print("✓ Successfully logged off from z/VM hypervisor")
        
        print("\nz/VM connection test: PASSED")
        return 0
        
    except Exception as e:
        print(f"✗ z/VM connection test FAILED: {str(e)}", file=sys.stderr)
        return 1

if __name__ == "__main__":
    # Get parameters from Ansible (passed via role vars from hostvars)
    zvm_name = "{{ node_name }}"           # Node name
    zvm_host = "{{ node_zvm_host }}"       # z/VM hypervisor hostname/IP
    zvm_user = "{{ node_zvm_user }}"       # z/VM user for this guest
    zvm_pass = "{{ node_zvm_pass }}"       # z/VM user password
    
    sys.exit(test_zvm_connection(zvm_name, zvm_host, zvm_user, zvm_pass))